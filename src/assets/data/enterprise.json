  "mobileSDK": {
    "kicker": "Mobile SDKs",
    "summary": "Native iOS and Android SDKs for in-app payments. Drop-in checkout UI or headless · your choice.",
    "sdks": [
      {
        "platform": "iOS",
        "version": "2.8.0",
        "language": "Swift",
        "minOS": "iOS 14.0+",
        "binarySize": "1.8 MB",
        "install": "pod 'Payze', '~> 2.8'",
        "installAlt": "SPM: https://github.com/payze/payze-ios · 2.8.0",
        "snippet": "import Payze\n\nlet client = PayzeClient(apiKey: \"pk_live_...\")\n\nclient.presentCheckout(\n    on: self,\n    amount: 249900,    // paise\n    currency: \"INR\",\n    onSuccess: { result in\n        print(\"Paid: \\(result.txnId)\")\n    }\n)"
      },
      {
        "platform": "Android",
        "version": "2.8.0",
        "language": "Kotlin · Java compatible",
        "minOS": "API 24 (Android 7.0)+",
        "binarySize": "2.1 MB",
        "install": "implementation 'com.payze:payze-android:2.8.0'",
        "installAlt": "Maven Central · sonatype snapshot repo for beta",
        "snippet": "import com.payze.android.PayzeClient\n\nval payze = PayzeClient.create(apiKey = \"pk_live_...\")\n\npayze.presentCheckout(\n    activity = this,\n    amount = 249900,    // paise\n    currency = \"INR\",\n    onSuccess = { result ->\n        Log.d(\"Paid\", result.txnId)\n    }\n)"
      },
      {
        "platform": "React Native",
        "version": "2.8.0",
        "language": "TypeScript",
        "minOS": "RN 0.72+",
        "binarySize": "0.9 MB (shared)",
        "install": "npm install @payze/react-native",
        "installAlt": "yarn add @payze/react-native · auto-linking",
        "snippet": "import { PayzeClient } from '@payze/react-native';\n\nconst payze = new PayzeClient({ apiKey: 'pk_live_...' });\n\nawait payze.presentCheckout({\n  amount: 249900,\n  currency: 'INR',\n  onSuccess: (r) => console.log('Paid:', r.txnId),\n});"
      },
      {
        "platform": "Flutter",
        "version": "2.8.0",
        "language": "Dart",
        "minOS": "Flutter 3.13+",
        "binarySize": "1.2 MB (shared)",
        "install": "flutter pub add payze_flutter",
        "installAlt": "pub.dev · payze_flutter ^2.8.0",
        "snippet": "import 'package:payze_flutter/payze.dart';\n\nfinal payze = PayzeClient(apiKey: 'pk_live_...');\n\nfinal result = await payze.presentCheckout(\n  amount: 249900,\n  currency: 'INR',\n);\nprint('Paid: ${result.txnId}');"
      }
    ],
