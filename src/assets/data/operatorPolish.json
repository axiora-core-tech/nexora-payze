{
  "fraudRules": {
    "kicker": "Fraud rules · live engine",
    "summary": "Visual rule builder. Set conditions, choose action. Hot-reloads in <30s. Test against last 30 days of traffic before shipping.",
    "stats": [
      { "label": "Active rules",    "value": "24",       "sub": "across 6 categories" },
      { "label": "Blocked · 30d",    "value": "1,824",   "sub": "₹84.2 L attempted fraud" },
      { "label": "False positives",  "value": "0.18%",   "sub": "industry 0.5-1.0%" },
      { "label": "Avg evaluation",   "value": "12 ms",   "sub": "p99 21 ms · pre-auth" }
    ],
    "categories": ["Velocity", "Amount", "Geo", "Device", "Behaviour", "BIN/Issuer"],
    "rules": [
      {
        "id": "rule_velocity_v2", "name": "velocity_anomaly_v2", "category": "Velocity", "active": true,
        "description": "More than 4 attempts from one device in 2 minutes",
        "conditions": [
          { "field": "device.attempts_in_window", "op": ">",  "value": "4" },
          { "field": "device.window_seconds",      "op": "==", "value": "120" }
        ],
        "action": "block", "fires30d": 482, "trueFraud30d": 478, "falsePositives30d": 4, "lastFired": "Today 14:28"
      },
      {
        "id": "rule_first_high",   "name": "first_time_high_value", "category": "Behaviour", "active": true,
        "description": "New customer (account age <14d) attempting >3x average ticket",
        "conditions": [
          { "field": "customer.account_age_days", "op": "<", "value": "14" },
          { "field": "txn.amount_vs_avg_ratio",   "op": ">", "value": "3" }
        ],
        "action": "step_up_3ds", "fires30d": 284, "trueFraud30d": 178, "falsePositives30d": 14, "lastFired": "Today 11:42"
      },
      {
        "id": "rule_geo_block",     "name": "blocked_geo_ips",        "category": "Geo", "active": true,
        "description": "IP geolocation in OFAC sanctioned countries",
        "conditions": [
          { "field": "ip.country", "op": "IN", "value": "OFAC_SDN_LIST" }
        ],
        "action": "block", "fires30d": 18, "trueFraud30d": 18, "falsePositives30d": 0, "lastFired": "Yesterday 09:14"
      },
      {
        "id": "rule_card_enum",     "name": "card_enumeration",       "category": "BIN/Issuer", "active": true,
        "description": "Different cards, same device, same BIN within 5 minutes (testing stolen list)",
        "conditions": [
          { "field": "device.distinct_pans_5min", "op": ">", "value": "3" },
          { "field": "device.same_bin_5min",       "op": "==", "value": "true" }
        ],
        "action": "block", "fires30d": 142, "trueFraud30d": 142, "falsePositives30d": 0, "lastFired": "Today 02:18"
      },
      {
        "id": "rule_billing_mismatch","name": "billing_ip_mismatch",  "category": "Geo", "active": true,
        "description": "IP country differs from billing country (high-amount only)",
        "conditions": [
          { "field": "ip.country", "op": "!=", "value": "card.billing_country" },
          { "field": "txn.amount", "op": ">", "value": "10000" }
        ],
        "action": "step_up_3ds", "fires30d": 142, "trueFraud30d": 89, "falsePositives30d": 18, "lastFired": "Today 12:38"
      },
      {
        "id": "rule_late_night",     "name": "late_night_high_amount","category": "Behaviour", "active": false,
        "description": "Transactions between 02:00-05:00 IST above ₹50,000",
        "conditions": [
          { "field": "time.hour_ist",     "op": "BETWEEN", "value": "[2,5]" },
          { "field": "txn.amount",        "op": ">",       "value": "50000" }
        ],
        "action": "step_up_3ds", "fires30d": 0, "trueFraud30d": 0, "falsePositives30d": 0, "lastFired": "—"
      }
    ],
    "actionPalette": [
      { "id": "block",         "label": "Block",         "color": "red",   "description": "Reject pre-authorization · customer sees error" },
      { "id": "step_up_3ds",   "label": "Step-up to 3DS","color": "amber", "description": "Force 3DS challenge · friction added" },
      { "id": "manual_review", "label": "Manual review", "color": "amber", "description": "Auth allowed but flagged · operator must approve before capture" },
      { "id": "log_only",      "label": "Log only",      "color": "teal",  "description": "Allow but log to risk register · for monitoring" }
    ],
    "fieldCatalog": [
      { "namespace": "txn",       "fields": ["amount", "amount_vs_avg_ratio", "currency", "method", "merchant_id"] },
      { "namespace": "customer",  "fields": ["account_age_days", "ltv", "prior_disputes", "first_payment"] },
      { "namespace": "device",    "fields": ["fingerprint", "attempts_in_window", "window_seconds", "distinct_pans_5min", "same_bin_5min", "vpn_detected"] },
      { "namespace": "ip",        "fields": ["country", "asn", "is_residential", "is_proxy"] },
      { "namespace": "card",      "fields": ["bin", "country", "billing_country", "is_prepaid", "issuer_risk_score"] },
      { "namespace": "time",      "fields": ["hour_ist", "day_of_week", "is_weekend"] }
    ]
  },
