{
  "channels": [
    {
      "id": "upi_push",
      "label": "UPI Collect Request",
      "subtitle": "Push notification to customer's UPI app · PhonePe · GPay · Paytm",
      "icon": "IconQR",
      "primary": true,
      "trustBadge": "Highest conversion · zero-tap payment",
      "detail": "Sends an intent to the customer's phone number. Their UPI app (PhonePe, GPay, Paytm, BHIM) pings them with a 'Pay ₹X to Y' prompt. They tap Pay. No link clicked, no page loaded. Expires in 10 minutes by default.",
      "avgConversion": "64%",
      "requiresPhone": true,
      "channelCost": "Free"
    },
    {
      "id": "sms",
      "label": "SMS",
      "subtitle": "DLT-registered template · 160-char message with payment link",
      "icon": "IconBell",
      "primary": true,
      "trustBadge": "TRAI-compliant · DLT-registered",
      "detail": "Shortened payment link delivered via Gupshup SMS gateway. DLT header and template pre-approved with TRAI. Delivery SLA 30 sec median. Tracked open → click → pay.",
      "avgConversion": "22%",
      "requiresPhone": true,
      "channelCost": "₹0.28 per SMS"
    },
    {
      "id": "whatsapp",
      "label": "WhatsApp",
      "subtitle": "Business API · HSM-approved template with payment link",
      "icon": "IconMail",
      "primary": true,
      "trustBadge": "Official API · no third-party",
      "detail": "Sent via Meta's WhatsApp Business API. Template pre-approved under utility category. Supports receipt PDF attachment. Delivery and read receipts tracked.",
      "avgConversion": "41%",
      "requiresPhone": true,
      "channelCost": "₹0.38 per conversation"
    },
    {
      "id": "email",
      "label": "Email",
      "subtitle": "Branded HTML with payment button · DKIM signed",
      "icon": "IconMail",
      "primary": false,
      "trustBadge": "DKIM signed · SPF validated",
      "detail": "Sent via SES with your merchant brand. DKIM and SPF aligned. Tracks open, click, device and geo.",
      "avgConversion": "12%",
      "requiresPhone": false,
      "channelCost": "Free · up to 10K/month"
    }
  ],
  "upiPushMechanics": {
    "title": "How UPI Collect Request works",
    "regulationRef": "NPCI UPI Collect Request spec v2.7 · BHIM-standard",
    "steps": [
      { "num": 1, "label": "Merchant submits intent",          "detail": "Payze pushes intent with amount, remarks, merchant name to NPCI switch" },
      { "num": 2, "label": "NPCI routes to customer's PSP",    "detail": "Identified by VPA lookup or registered phone → PSP mapping" },
      { "num": 3, "label": "Customer's UPI app pings them",    "detail": "Silent push notification → 'Pay ₹X to Y' modal in the app" },
      { "num": 4, "label": "Customer approves with PIN",       "detail": "Single biometric + UPI PIN → debit authorised" },
      { "num": 5, "label": "NPCI settles · Payze webhook fires","detail": "payment.succeeded webhook delivered to merchant backend within 2 seconds" }
    ],
    "timeoutMinutes": 10,
    "cancellable": true
  },
  "smsTemplates": [
